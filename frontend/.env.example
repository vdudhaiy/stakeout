# Frontend environment (Vite). Copy to .env.local for development.

# Base URL of the Stakeout API. Leave empty in dev — Vite proxies /stocks,
# /portfolio, etc. to http://localhost:8000. In production (Vercel) set this
# to your Render service URL, e.g. https://stakeout-api.onrender.com
VITE_API_URL=

# Supabase project credentials (Project Settings → API). Leave both empty to
# run in local single-user mode with no accounts.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Polling intervals (milliseconds) ──────────────────────────────────────
# All optional — each falls back to the default shown if unset or invalid.
# VITE_HEALTH_REFRESH_MS=30000        # /health check (default: 30s)
# VITE_MARKET_STATUS_REFRESH_MS=300000  # US/IN market open-closed status (default: 5min)
# VITE_PRICE_REFRESH_MS=120000        # live price while market open/pre-market (default: 2min)
# VITE_PORTFOLIO_REFRESH_MS=120000    # portfolio holdings reload (default: 2min)
# VITE_TICKER_TAPE_REFRESH_MS=300000  # ticker tape quotes (default: 5min)
