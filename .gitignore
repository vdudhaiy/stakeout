# General ignores
venv/
.env
__pycache__/
*.pyc
*.pyo

# OS files
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp

# Ignore logs, data, model artifacts, and database files
logs/
data/
model-store/
*.db
*.sqlite

# Ignore Python packaging artifacts
*.egg-info
.venv/

# PyInstaller build output (executables go to dist/, already ignored above)
build/

# Pytest cache and coverage reports
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# Other Python tool caches
.ruff_cache/
.mypy_cache/
.tox/

# Frontend
node_modules/
dist/
dist-ssr/
*.local
.env.local
.env.*.local
.vite/
*.tsbuildinfo
npm-debug.log*
yarn-error.log*