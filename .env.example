# Copy this file to .env and fill in values for your environment.
# .env is gitignored; .env.example is committed as documentation.

# Logging configuration
LOG_DIR = 'logs/'
LOG_LEVEL = "DEBUG"

# Price data fetcher configuration
# Earliest date to fetch stock data from. Price data itself lives in the
# market_data table (see DATABASE_URL below), not on disk.
ARCHIVE_START_DATE = '2023-01-01'
# Base directory for all writable local files (logs, model artefacts).
# Leave empty in dev mode — the backend defaults to the repo root.
MARKET_LENS_DATA_DIR = ""

# Model configuration
MODEL_DIR = 'model-store/'

# Optional: override the FastAPI app title shown in /docs
# APP_NAME = "Stakeout"

# ── Database ───────────────────────────────────────────────────────────────
# Independent of SUPABASE_JWKS_URL below — this only controls where portfolio/
# watchlist rows are stored, not how sign-in is verified. Leave unset for local
# dev (SQLite file at the repo root) even if you set SUPABASE_JWKS_URL to test
# real sign-in locally — your local data then stays fully on your machine,
# separate from whatever's in production.

# Postgres connection string. For Supabase, use the *Session pooler* URI from
# Project Settings → Database, with the asyncpg scheme:
#   postgresql+asyncpg://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
# Required for a deployed instance. Unset → local SQLite file (fine for dev).
# DATABASE_URL = ""

# ── Auth ─────────────────────────────────────────────────────────────────
# Required for a deployed instance. For local dev you have three options:
#   1. Leave unset — the app automatically falls back to its own local
#      email/password accounts (stored in your local SQLite database, see
#      routers/local_auth.py). No cloud project needed at all.
#   2. Also skip creating a local account and click "Continue as Guest" in
#      the app instead — data then lives only in the browser for that session.
#   3. Set this (and the frontend's VITE_SUPABASE_URL/VITE_SUPABASE_ANON_KEY)
#      to test real Supabase sign-in locally. DATABASE_URL above can still be
#      left unset — your account's data will just live in your local SQLite
#      file instead of production's database.

# Supabase JWKS URL (Project Settings → API → JWT Keys → JWKS URL), e.g.
#   https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
# SUPABASE_JWKS_URL = ""

# Comma-separated list of allowed browser origins for CORS, e.g. your Vercel URL:
#   https://stakeout.vercel.app,http://localhost:5173
# CORS_ORIGINS = ""
