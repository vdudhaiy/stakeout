# Copy this file to .env and fill in values for your environment.
# .env is gitignored; .env.example is committed as documentation.

# Logging configuration
LOG_DIR = 'logs/'
LOG_LEVEL = "DEBUG"

# Price data fetcher configuration
ARCHIVE_DATA_DIR = 'data/archive_stock_data/'
ARCHIVE_START_DATE = '2023-01-01'
# Base directory for all writable data (stock CSVs, logs, model artefacts).
# Leave empty in dev mode — the backend defaults to the repo root.
# The packaged executable sets this automatically to stakeout-data/ next to the binary.
MARKET_LENS_DATA_DIR = ""

# Model configuration
MODEL_DIR = 'model-store/'

# Optional: override the FastAPI app title shown in /docs
# APP_NAME = "Stakeout"

# ── Deployment (production only — leave unset for local dev) ─────────────────

# Postgres connection string. For Supabase, use the *Session pooler* URI from
# Project Settings → Database, with the asyncpg scheme:
#   postgresql+asyncpg://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
# Unset → local SQLite file.
# DATABASE_URL = ""

# Supabase JWT secret (Project Settings → API → JWT Secret). When set, the API
# verifies Supabase auth tokens and scopes data per user. Unset → single-user
# "local" mode with no authentication (the desktop default).
# SUPABASE_JWT_SECRET = ""

# Comma-separated list of allowed browser origins for CORS, e.g. your Vercel URL:
#   https://stakeout.vercel.app,http://localhost:5173
# CORS_ORIGINS = ""
